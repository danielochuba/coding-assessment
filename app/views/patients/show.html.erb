<div class="bg-white shadow-md rounded-lg p-6 w-[60%] m-auto mt-[40px] min-h-[60vh]">
    <h1 class="text-center text-2xl font-semibold text-cyan-500 mb-8">Patient Details</h1>

    <table class="min-w-full table-auto border border-gray-300">
        <thead>
            <tr>
                <th class="px-4 py-2">Name</th>
                <th class="px-4 py-2">Age</th>
                <th class="px-4 py-2">Address</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <%= render @patient %>
            </tr>
        </tbody>
    </table>

    <div class="w-full flex justify-center mt-6 gap-4">
        <% if can? :update, @patient %>
        <%= link_to "Edit Patient", edit_patient_path(@patient), 
          class: 'bg-yellow-500 hover:bg-yellow-700 text-white font-bold py-2 px-4 rounded' %>
        <% end %>
        <%= link_to "Back to Patients", patients_path, 
        class: 'bg-gray-500 hover:bg-gray-700 text-white font-bold py-2 px-4 rounded' %>
        <% if can? :delete, @patient %>
        <%= button_to "Delete Patient", @patient, method: :delete, 
          class: 'bg-red-500 hover:bg-red-700 text-white font-bold py-2 px-4 rounded',
          form: { data: { turbo_confirm: "Are you sure you want to delete this patient?" } } %>
        <% end %>
    </div>
</div>