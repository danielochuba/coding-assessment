<%
=begin%>
 <div class="container mx-auto p-4">
  <div class="text-center mb-8">
    <h1 class="text-4xl font-bold text-gray-800">Clinic Portal Management System</h1>
    <p class="text-lg text-gray-600 mt-2">Manage Patients and Appointments</p>
  </div>

  <% if user_signed_in? %>
    <div class="text-center">
      <% if current_user.doctor? %>
        <a href="<%= dashboard_path %>" class="btn btn-primary mr-4">Dashboard</a>
      <% elsif current_user.receptionist? %>
        <a href="<%= patients_path %>" class="btn btn-primary mr-4">Patients</a>
        <a href="<%= new_patient_path %>" class="btn btn-secondary">New Patient</a>
      <% end %>
      <%= link_to 'Sign Out', destroy_user_session_path, method: :delete, class: 'btn btn-danger' %>
    </div>
  <% else %>
    <div class="text-center">
      <%= link_to 'Sign Up', new_user_registration_path, class: 'text-white border p-2 rounded-md m-2 border-gray-200 bg-orange-400' %>
      <%= link_to 'Log In', new_user_session_path, class: 'text-white border p-2 rounded-md m-2 border-gray-200 bg-yellow-400' %>
    </div>
  <% end %>

  <div class="mt-12">
    <h2 class="text-2xl font-bold text-gray-700 mb-4">Features</h2>
    <ul class="list-disc list-inside">
      <li class="mb-2">Manage patient records</li>
      <li class="mb-2">Schedule doctor appointments</li>
      <li class="mb-2">View patient statistics</li>
    </ul>
  </div>

</div> 
<%
=end%>

<div class="min-h-screen bg-cover bg-center flex flex-col justify-center items-center px-4 py-16 text-white" style="background-image: url('<%= asset_path("healthcare.jpg") %>'); background-size: cover; background-position: center; height: 100vh;">
  <div class="backdrop-blur-sm shadow-lg rounded-2xl p-10 max-w-3xl w-[35%] ">
    <h1 class="text-4xl text-white sm:text-5xl font-extrabold text-gray-800 mb-2">
      Clinic Portal
    </h1>
    <h1 class="text-4xl text-white sm:text-5xl font-extrabold text-gray-800 mb-2">
      Management System
    </h1>
    <p class="text-lg text-gray-600 mb-8 text-white">Manage Patients and Appointments</p>

    <% if user_signed_in? %>
      <div class="flex flex-wrap justify-center gap-4 mb-8">
        <% if current_user.doctor? %>
          <%= link_to 'Dashboard', dashboard_path, class: 'bg-blue-600 hover:bg-blue-700 text-white font-medium px-6 py-3 rounded-lg shadow-md transition' %>
        <% elsif current_user.receptionist? %>
          <%= link_to 'Patients', patients_path, class: 'bg-indigo-600 hover:bg-indigo-700 text-white font-medium px-6 py-3 rounded-lg shadow-md transition' %>
          <%= link_to 'New Patient', new_patient_path, class: 'bg-green-500 hover:bg-green-600 text-white font-medium px-6 py-3 rounded-lg shadow-md transition' %>
        <% end %>
        <%= link_to 'Sign Out', destroy_user_session_path, method: :delete, class: 'bg-red-500 hover:bg-red-600 text-white font-medium px-6 py-3 rounded-lg shadow-md transition' %>
      </div>
    <% else %>
      <div class="inline  gap-4 mb-8">
        <%= link_to 'Sign Up', new_user_registration_path, class: 'bg-gray-700 hover:bg-orange-600 text-white font-medium p-2 rounded-lg shadow-md transition' %>
        <%= link_to 'Log In', new_user_session_path, class: 'bg-yellow-400 hover:bg-yellow-500 text-white font-medium p-2 rounded-lg shadow-lg transition' %>
      </div>
    <% end %>

  </div>
</div>

