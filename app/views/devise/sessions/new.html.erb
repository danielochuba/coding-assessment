<div class="flex items-center justify-center shadow-md rounded-lg p-6 w-[60%] bg-white m-auto mt-[40px]">
    <div class="w-full max-w-md bg-white rounded-lg  p-8 m-4">
        <div class="text-center mb-8">
            <h2 class="text-3xl font-bold text-gray-800 mb-2">Welcome Back</h2>
            <p class="text-sm text-gray-600">Sign in to your account to continue</p>
        </div>

        <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="mb-4">
            <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <div class="relative">
                <div class="absolute left-0 flex items-center h-full pl-3 pointer-events-none">
                </div>
                <%= f.email_field :email, autofocus: true, class: 'w-full p-2 pl-10 border border-gray-300 rounded-md', placeholder: "you@example.com", autocomplete: "email" %>
            </div>
        </div>

        <div class="mb-4">
            <div class="flex justify-between mb-1">
                <%= f.label :password, class: "block text-sm font-medium text-gray-700" %>
                <% if devise_mapping.recoverable? %>
                <%= link_to "Forgot password?", new_password_path(resource_name), class: "text-sm text-blue-600 hover:underline" %>
                <% end %>
            </div>
            <div class="relative">
                <div class="absolute left-0 flex items-center h-full pl-3 pointer-events-none">
                </div>
                <%= f.password_field :password, class: 'w-full p-2 pl-10 border border-gray-300 rounded-md', placeholder: "••••••••", autocomplete: "current-password" %>
            </div>
        </div>

        <% if devise_mapping.rememberable? %>
        <div class="flex items-center mb-4">
            <%= f.check_box :remember_me, class: 'h-4 w-4 mr-2 text-blue-600 border-gray-300 rounded' %>
            <%= f.label :remember_me, class: "text-sm text-gray-700" %>
        </div>
        <% end %>

        <div class="mb-4">
            <%= f.submit "Sign in", class: "w-full p-2 bg-blue-500 text-white rounded-md font-medium hover:bg-blue-700 transition-colors duration-200" %>
        </div>
        <% end %>

        <div class="mt-6 text-center">
            <p class="text-sm text-gray-600 mb-4">Don't have an account?</p>
            <% if devise_mapping.registerable? %>
            <%= link_to "Create an account", new_registration_path(resource_name), class: "w-full inline-block p-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-100 transition-colors duration-200" %>
            <% end %>
        </div>
    </div>
</div>