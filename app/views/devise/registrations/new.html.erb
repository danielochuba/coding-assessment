<div class="max-h-[80vh] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8 bg-gradient-to-r from-blue-50 to-indigo-50 bg-white rounded-lg p-6 w-[60%] m-auto mb-[40px] overflow-scroll">
    <div class=" max-w-md w-full bg-white rounded-xl overflow-scroll p-2">
        <div class="mb-6 text-center">
            <h2 class="text-3xl font-extrabold text-gray-900 mb-2">Create Account</h2>
            <p class="text-sm text-gray-600">Join our medical platform</p>
        </div>

        <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="grid grid-cols-2 gap-4">
            <div class="field">
                <%= f.label :first_name, class: "block text-sm font-medium text-gray-700 mb-1" %>
                <div class="relative rounded-md shadow-sm">
                    <div class="absolute left-0 flex items-center h-full pl-3 pointer-events-none">
                    </div>
                    <%= f.text_field :first_name, autofocus: true, class: 'pl-2 pr-3 py-2 w-full border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500', placeholder: "First Name", autocomplete: "first_name" %>
                </div>
            </div>

            <div class="field">
                <%= f.label :last_name, class: "block text-sm font-medium text-gray-700 mb-1 mt-2" %>
                <div class="relative rounded-md shadow-sm">
                    <div class="absolute left-0 flex items-center h-full pl-3 pointer-events-none">
                    </div>
                    <%= f.text_field :last_name, class: 'pl-10 pr-3 py-2 w-full border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500', placeholder: "Last Name", autocomplete: "last_name" %>
                </div>
            </div>
        </div>

        <div class="field">
            <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <div class="relative rounded-md shadow-sm">
                <div class="absolute left-0 flex items-center h-full pl-3 pointer-events-none">

                </div>
                <%= f.email_field :email, class: 'pl-10 pr-3 py-2 w-full border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500', placeholder: "you@example.com", autocomplete: "email" %>
            </div>
        </div>

        <div class="field">
            <%= f.label :role, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <div class="relative rounded-md shadow-sm">
                <div class="absolute left-0 flex items-center h-full pl-3 pointer-events-none">

                </div>
                <%= f.select :role, ["Receptionist", "Doctor"], { prompt: "Select your role" }, 
              class: 'pl-10 pr-3 py-2 w-full border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500 bg-white' %>
            </div>
        </div>

        <div class="field">
            <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <% if @minimum_password_length %>
            <span class="text-xs text-gray-500">(<%= @minimum_password_length %> characters minimum)</span>
            <% end %>
            <div class="relative rounded-md shadow-sm">
                <div class="absolute left-0 flex items-center h-full pl-3 pointer-events-none">

                </div>
                <%= f.password_field :password, class: 'pl-10 pr-3 py-2 w-full border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500', placeholder: "••••••••", autocomplete: "new-password" %>
            </div>
        </div>

        <div class="field">
            <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <div class="relative rounded-md shadow-sm">
                <div class="absolute left-0 flex items-center h-full pl-3 pointer-events-none">

                </div>
                <%= f.password_field :password_confirmation, class: 'pl-10 pr-3 py-2 w-full border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500', placeholder: "••••••••", autocomplete: "new-password" %>
            </div>
        </div>

        <div class="w-full flex justify-center">
            <%= f.submit "Sign up",  class: 'bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded ' %>
        </div>
        <% end %>

        <div class="mt-6">
            <div class="relative">
                <div class="absolute inset-0 flex items-center">
                    <div class="w-full border-t border-gray-300"></div>
                </div>
                <div class="relative flex justify-center text-sm">
                    <span class="px-2 bg-white text-gray-500">Already have an account?</span>
                </div>
            </div>

            <div class="mt-6">
                <%= link_to "Sign in instead", new_session_path(resource_name), class: "w-full flex justify-center py-2 px-4  rounded-lg shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors duration-200" %>
            </div>
        </div>
    </div>
</div>